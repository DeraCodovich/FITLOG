{
  "version": 2,

  "outputDirectory": "Для GetHub",

  "functions": {
    "api/claude.js": {
      "maxDuration": 30,
      "memory": 256
    }
  },

  "rewrites": [
    {
      "source": "/",
      "destination": "/fitness-tracker.html"
    }
  ],

  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
