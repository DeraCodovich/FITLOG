{
  "version": 2,

  "functions": {
    "api/claude.js": {
      "maxDuration": 30,
      "memory": 256
    }
  },

  "rewrites": [
    {
      "source": "/",
      "destination": "/Для GetHub/fitness-tracker.html"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/Для GetHub/$1"
    }
  ],

  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
